{
  "name": "admin-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:backend": "node scripts/run-npm.mjs run dev --prefix backend",
    "dev:frontend": "node scripts/run-npm.mjs run dev --prefix frontend",
    "install:all": "node scripts/install-all.mjs",
    "start:backend": "node scripts/run-npm.mjs run start --prefix backend",
    "start:frontend": "node scripts/run-npm.mjs run dev --prefix frontend",
    "build": "node scripts/run-npm.mjs run build --prefix frontend",
    "deploy:lightsail": "node scripts/install-all.mjs && node scripts/run-npm.mjs run build --prefix frontend",
    "start": "node scripts/run-npm.mjs run start --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
